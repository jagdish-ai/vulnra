# ── VULNRA Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For local development with Docker: see docker-compose.yml for defaults.
# Required vars are marked with (REQUIRED)

# ── Security (REQUIRED) ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-change-me-local-only

# ── Celery / Redis ──────────────────────────────────────────────────────────
# Main scans run via FastAPI background tasks (no Redis needed).
# Celery is only required for scheduled scans and sentinel monitoring.
# Set CELERY_ENABLED=true and add a Redis URL to use those features.
CELERY_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Local Supabase (run: supabase start):
#   SUPABASE_URL=http://localhost:54321
#   SUPABASE_SERVICE_KEY=eyJ... (the service_role key from supabase status)
#
# Cloud Supabase (find at: https://supabase.com/dashboard → Your Project → Settings → API):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35l4oWWArLC-nDOe8_8XwIsM_gnd0s5iI

# ── Gemini API (REQUIRED for AI Judge, GuardianForge, EasyJailbreak) ────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GUARDIAN_GEMINI_MODEL=gemini-1.5-flash

# ── Lemon Squeezy (for billing - optional for local dev) ────────────────────
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── Email (for Sentinel alerts - optional) ──────────────────────────────────
RESEND_API_KEY=your-resend-api-key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── App Settings ─────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
# API_URL is used by the Celery worker for internal callbacks.
# In Docker, set to: http://backend:8000
# Locally, set to:   http://localhost:8000
API_URL=http://localhost:8000

# ── Frontend URL (for CORS + redirects) ─────────────────────────────────────
# In Docker, set to: http://frontend:3000
# Locally, set to:   http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In Docker, include: http://frontend:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000,http://localhost:8000

# ── OpenAI (optional - only needed for DeepTeam engine) ────────────────────
# OPENAI_API_KEY=sk-your-key-here
